# Copy this to .env.local and fill in every value.
# Never commit .env.local to git.

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── MongoDB Atlas ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/latex-report-studio?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex_string

# ─── Encryption (for storing Gemini API keys) ───────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_string

# ─── AWS S3 ─────────────────────────────────────────────────────────────────
# Create a bucket, an IAM user scoped to just that bucket (s3:PutObject,
# s3:GetObject, s3:DeleteObject), and a bucket policy allowing public
# s3:GetObject reads (images/diagrams need to load in <img> tags and in the
# compiled PDF/LaTeX export). See README for the exact bucket policy JSON.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_iam_user_access_key_id
AWS_SECRET_ACCESS_KEY=your_iam_user_secret_access_key
AWS_S3_BUCKET_NAME=your-bucket-name
# Optional: set this if you front the bucket with a CloudFront distribution
# or another CDN. Leave unset to use the bucket's own regional S3 endpoint.
# AWS_S3_PUBLIC_URL_BASE=https://cdn.example.com

# ─── Gemini (AI Humanizer / LaTeX Convert) ─────────────────────────────────
# Users bring their own Gemini API key via Settings — nothing to configure
# here. Optionally override which model the server calls (must be a
# currently-supported, non-deprecated model — check ai.google.dev/gemini-api/docs/pricing):
# GEMINI_MODEL=gemini-2.5-flash

# ─── Email (Gmail SMTP) ─────────────────────────────────────────────────────
# Use a Gmail App Password — NOT your regular password.
# Generate at: myaccount.google.com → Security → App Passwords
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM="LaTeX Report Studio <youremail@gmail.com>"
